{
  "name": "worker",
  "scripts": {
    "build": "pnpm run ncc",
    "clean": "rm -rf dist",
    "dev": "node dist/index.js",
    "lint": "eslint .",
    "ncc": "ncc build src/index.ts --out dist --target es2023 --external sharp",
    "prisma": "prisma generate",
    "prebuild": "pnpm run clean && pnpm run types",
    "types": "tsc"
  },
  "dependencies": {
    "@brickcatalog/database": "workspace:*",
    "cron-parser": "5.5.0",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@brickninja/standard": "workspace:*",
    "@types/node": "24.12.2",
    "@vercel/ncc": "0.38.4"
  }
}
