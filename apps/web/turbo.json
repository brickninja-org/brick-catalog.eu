{
  "$schema": "https://turborepo.dev/schema.json",
  "extends": [
    "//"
  ],
  "tasks": {
    "dev": {
      "dependsOn": [
        "^build",
        "@brickcatalog/database#prisma:migrate"
      ]
    },
    "build": {
      "outputs": [
        ".next/**",
        "!.next/cache/**"
      ],
      "env": ["SKIP_TYPES", "DEPLOYMENT_ID"]
    }
  }
}
