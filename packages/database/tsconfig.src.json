{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@brickninja/standard/tsconfig/base.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./dist/tsconfig.src.tsbuildinfo",

    "noEmit": false,

    "rootDir": "./src",
    "outDir": "./dist",

    "module": "nodenext",
    "moduleResolution": "nodenext",

    "declarationMap": true
  },
  "include": ["./src"]
}
